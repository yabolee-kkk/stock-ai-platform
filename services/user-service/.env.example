# 服务器配置
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
SERVICE_NAME=user-service

# 数据库配置
DATABASE_URL=postgresql://stockai:stockai_password@localhost:5432/stockai_platform
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# Redis配置
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=change_this_to_a_secure_random_string_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=stock-ai-platform

# 密码加密
BCRYPT_SALT_ROUNDS=12

# 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# CORS配置
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true

# 日志配置
LOG_DIR=./logs
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=14d

# 邮件配置（用于密码重置等）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM=noreply@stockai.example.com

# API密钥配置
API_KEY_HEADER=X-API-Key

# 模板配置（用户偏好）
DEFAULT_TEMPLATE_TYPE=stock_info
DEFAULT_TEMPLATE_NAME=简洁版
ENABLE_TEMPLATE_CUSTOMIZATION=true